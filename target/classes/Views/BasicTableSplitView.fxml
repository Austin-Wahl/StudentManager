<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.VBox?>

<VBox
    style="-fx-background-color: #0a0a0a;"
    xmlns="http://javafx.com/javafx/25"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="controllers.TableViewController">
    <GridPane minHeight="200" maxHeight="200"
              style="-fx-background-color: #0a0a0a; -fx-padding: 16;">
        <columnConstraints>
            <ColumnConstraints hgrow="ALWAYS" percentWidth="33.33" />
            <ColumnConstraints hgrow="ALWAYS" percentWidth="33.33" />
            <ColumnConstraints hgrow="ALWAYS" percentWidth="33.33" />
        </columnConstraints>
        <children>
            <VBox GridPane.columnIndex="0" spacing="6"
                  style="-fx-padding: 8;">
                <children>
                    <Label text="About This Project"
                           style="-fx-text-fill: white; -fx-font-size: 16;" />
                    <Label text="100,000 Records"
                           style="-fx-text-fill: white; -fx-font-size: 13;" />
                    <Label text="Data Structures: HashTable and PriorityQueue"
                           style="-fx-text-fill: white; -fx-font-size: 13;" />
                    <Label text="Members: Austin Wahl, Antonio Nieto, Abel Martinez"
                           style="-fx-text-fill: white; -fx-font-size: 13;" />
                </children>
            </VBox>
            <VBox GridPane.columnIndex="1" alignment="CENTER">
                <children>
                    <Label text="Student Manager"
                           style="-fx-text-fill: white; -fx-font-size: 20;" />
                </children>
            </VBox>
            <VBox GridPane.columnIndex="2">
            </VBox>
        </children>
    </GridPane>
    <SplitPane VBox.vgrow="ALWAYS"
               dividerPositions="0.5"
               style="-fx-background-color: #0a0a0a;">
        <items>
            <TableView fx:id="leftHandSideTable" prefHeight="1920.0" prefWidth="1080.0" style="-fx-border-color: #ffffff1a; -fx-background-color: #0a0a0a;">
         <columns>
            <TableColumn fx:id="lhs_uuid" prefWidth="134.22055053710938" style="-fx-background-color: #0a0a0a; -fx-border-color: ffffff1a;" text="Student UUID" />
            <TableColumn fx:id="lhs_name" prefWidth="75.0" style="-fx-background-color: #0a0a0a; -fx-border-color: ffffff1a;" text="Name" />
            <TableColumn fx:id="lhs_email" prefWidth="75.0" style="-fx-background-color: #0a0a0a; -fx-border-color: ffffff1a;" text="Email" />
            <TableColumn fx:id="lhs_gpa" prefWidth="75.0" style="-fx-background-color: #0a0a0a; -fx-border-color: ffffff1a;" text="GPA" />
         </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
      <TableView fx:id="rightHandSideTable" prefHeight="1920.0" prefWidth="1080.0" style="-fx-border-color: #ffffff1a; -fx-background-color: #0a0a0a;">
         <columns>
            <TableColumn fx:id="rhs_uuid" prefWidth="134.22055053710938" style="-fx-background-color: #0a0a0a;" text="Student UUID" />
            <TableColumn fx:id="rhs_name" prefWidth="75.0" style="-fx-background-color: #0a0a0a;" text="Name" />
            <TableColumn fx:id="rhs_email" prefWidth="75.0" style="-fx-background-color: #0a0a0a;" text="Email" />
            <TableColumn fx:id="rhs_gpa" prefWidth="75.0" style="-fx-background-color: #0a0a0a;" text="GPA" />
         </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
        </items>
    </SplitPane>

</VBox>
